.page {
  position: relative;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100vh;
}

.map-overlay {
  position: fixed;
  inset: 0;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 20;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.avatar-entry {
  pointer-events: auto;
  padding: 12rpx 16rpx;
  border-radius: 40rpx;
  background: var(--bg-glass);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 64rpx;
  backdrop-filter: blur(10px);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.avatar-entry:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.avatar-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: var(--gray-200);
}

.avatar-placeholder {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, var(--brand-500), var(--brand-700));
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
}

.avatar-copy {
  display: flex;
}

.avatar-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.2;
}

.logout-top {
  pointer-events: auto;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: var(--bg-glass);
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  transition: all 0.2s ease;
}

.logout-top:active {
  background: var(--error-100);
  border-color: var(--error-500);
}

.logout-text {
  color: var(--error-500);
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.login-mask {
  position: fixed;
  inset: 0;
  background: var(--bg-overlay);
  backdrop-filter: blur(4px);
  z-index: 30;
}

.login-panel {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: var(--shadow-xl);
  z-index: 31;
}

.login-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

.login-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  text-align: center;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 40rpx;
  margin-bottom: 24rpx;
}

.picker-avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--gray-200);
  border: 2rpx solid var(--border-light);
}

.picker-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--brand-50);
  color: var(--brand-600);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx dashed var(--brand-300);
}

.avatar-picker-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: var(--brand-50);
  color: var(--brand-700);
  font-size: 26rpx;
  font-weight: 500;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  transition: all 0.2s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.avatar-picker-btn::after {
  border: none;
}

.avatar-picker-btn:active {
  background: var(--brand-100);
}

.nick-row {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.nick-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--gray-100);
  color: var(--gray-500);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
}

.nickname-picker-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: var(--gray-100);
  color: var(--gray-700);
  font-size: 26rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  transition: all 0.2s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nickname-picker-btn::after {
  border: none;
}

.nickname-picker-btn:active {
  background: var(--gray-200);
}

.nickname-hidden-input {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  opacity: 0;
  pointer-events: none;
}

.login-actions {
  display: flex;
  gap: 20rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  border-radius: 14rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  transition: all 0.2s ease;
}

.cancel-btn {
  background: var(--gray-100);
  color: var(--gray-700);
}

.cancel-btn::after,
.confirm-btn::after {
  border: none;
}

.cancel-btn:active {
  background: var(--gray-200);
}

.confirm-btn {
  background: linear-gradient(135deg, var(--brand-500), var(--brand-700));
  color: var(--white);
  box-shadow: var(--shadow-brand);
}

.confirm-btn:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-md);
}
