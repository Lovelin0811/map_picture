.page {
  position: relative;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100vh;
}

.map-overlay {
  position: fixed;
  inset: 0;
  padding: 24rpx;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 20;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.avatar-entry {
  pointer-events: auto;
  padding: 10rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 228, 222, 0.95);
  box-shadow: 0 10rpx 24rpx rgba(22, 38, 33, 0.14);
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 72rpx;
}

.avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e2e8f0;
}

.avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: var(--brand-main);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.avatar-copy {
  display: flex;
}

.avatar-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
}

.logout-top {
  pointer-events: auto;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(214, 228, 222, 0.95);
  color: #ab2d3b;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(22, 38, 33, 0.12);
}

.hint-card {
  pointer-events: auto;
  margin-top: 18rpx;
  max-width: 510rpx;
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  background: rgba(12, 30, 26, 0.76);
}

.hint-title {
  display: block;
  color: #f3faf7;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hint-text {
  display: block;
  color: #d6e5df;
  font-size: 22rpx;
  margin-top: 8rpx;
  line-height: 1.45;
}

.login-mask {
  position: fixed;
  inset: 0;
  background: rgba(9, 18, 16, 0.5);
  z-index: 30;
}

.login-panel {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  top: 220rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #e4efea;
  box-shadow: 0 22rpx 40rpx rgba(20, 33, 29, 0.2);
  z-index: 31;
}

.login-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.login-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.45;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  margin-bottom: 16rpx;
}

.picker-avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #e2e8f0;
}

.picker-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #eef6f2;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.avatar-picker-btn {
  margin: 0;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  background: #edf7f3;
  color: #1e5f56;
  font-size: 24rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.avatar-picker-btn::after {
  border: none;
}

.nick-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.nick-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #eef6f2;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.nick-input-inline {
  flex: 1;
  height: 66rpx;
  line-height: 66rpx;
  border: 1rpx solid #ceded8;
  border-radius: 14rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  background: #ffffff;
}

.login-actions {
  display: flex;
  gap: 12rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  border-radius: 14rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.cancel-btn {
  background: #f3f7f5;
  color: #49655d;
}

.cancel-btn::after,
.confirm-btn::after {
  border: none;
}

.confirm-btn {
  background: var(--brand-main);
  color: #ffffff;
}
