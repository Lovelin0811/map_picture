.page {
  position: relative;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100vh;
}

.avatar-entry {
  position: fixed;
  left: 20rpx;
  top: 24rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 20;
}

.avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e2e8f0;
}

.avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #0f766e;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.avatar-text {
  font-size: 22rpx;
  color: #0f172a;
}

.logout-top {
  position: fixed;
  top: 34rpx;
  right: 22rpx;
  z-index: 21;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  color: #b91c1c;
  font-size: 22rpx;
  padding: 0 4rpx;
  background: transparent;
}

.login-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 30;
}

.login-panel {
  position: fixed;
  left: 44rpx;
  right: 44rpx;
  top: 260rpx;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.18);
  z-index: 31;
}

.login-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 18rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.picker-avatar-img {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #e2e8f0;
}

.picker-avatar-placeholder {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #f1f5f9;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.avatar-picker-btn {
  margin: 0;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 10rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 24rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.avatar-picker-btn::after {
  border: none;
}

.nick-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.nick-placeholder {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #f1f5f9;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.nick-input-inline {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 10rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
  background: #ffffff;
}

.login-actions {
  display: flex;
  gap: 12rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  border-radius: 10rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.cancel-btn {
  background: #f1f5f9;
  color: #334155;
}

.cancel-btn::after,
.confirm-btn::after {
  border: none;
}

.confirm-btn {
  background: #0f766e;
  color: #ffffff;
}
