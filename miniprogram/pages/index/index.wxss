.page {
  position: relative;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100vh;
}

.map-overlay {
  position: fixed;
  inset: 0;
  padding: 24rpx;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 20;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.avatar-entry {
  pointer-events: auto;
  padding: 10rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 228, 222, 0.95);
  box-shadow: 0 10rpx 24rpx rgba(22, 38, 33, 0.14);
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 72rpx;
}

.avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e2e8f0;
}

.avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: var(--brand-main);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.avatar-copy {
  display: flex;
}

.avatar-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
}

.logout-top {
  pointer-events: auto;
  min-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 228, 222, 0.95);
  box-shadow: 0 10rpx 24rpx rgba(22, 38, 33, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-text {
  color: #ab2d3b;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}
