<view class="page">
  <map
    class="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="4"
    min-scale="3"
    max-scale="12"
    show-location
    enable-poi="{{false}}"
    enable-zoom="{{true}}"
    enable-rotate="{{false}}"
    enable-3D="{{false}}"
    markers="{{markers}}"
    bindlabeltap="onLabelTap"
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
  />

  <view class="map-overlay">
    <view class="topbar">
      <view class="avatar-entry" bindtap="onTapLogin">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">{{authStatus === 'loading' ? '...' : '登'}}</view>
        <view class="avatar-copy">
          <text class="avatar-text">{{authText}}</text>
        </view>
      </view>

      <view wx:if="{{authStatus === 'success'}}" class="logout-top" catchtap="onLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>

  </view>

  <view wx:if="{{profilePanelVisible}}" class="profile-mask" bindtap="onCancelProfile"></view>
  <view wx:if="{{profilePanelVisible}}" class="profile-panel">
    <text class="profile-title">完善资料</text>
    <text class="profile-subtitle">登录已完成，可在这里设置头像和昵称。</text>

    <view class="profile-avatar-row">
      <image wx:if="{{pendingAvatarUrl}}" class="profile-avatar-img" src="{{pendingAvatarUrl}}" mode="aspectFill" />
      <view wx:else class="profile-avatar-placeholder">头像</view>
      <button class="profile-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        {{pendingAvatarUrl ? '重新选择' : '选择头像'}}
      </button>
    </view>

    <view class="profile-nick-row">
      <view class="profile-nick-placeholder">昵称</view>
      <input
        class="profile-nick-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{pendingNickName}}"
        bindblur="onNicknameInput"
      />
    </view>

    <view class="profile-actions">
      <button class="profile-cancel-btn" bindtap="onCancelProfile">取消</button>
      <button class="profile-confirm-btn" bindtap="onConfirmProfile">保存</button>
    </view>
  </view>
</view>
