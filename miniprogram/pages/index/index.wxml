<view class="page">
  <map
    class="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="4"
    min-scale="3"
    max-scale="12"
    show-location
    enable-poi="{{false}}"
    enable-zoom="{{true}}"
    enable-rotate="{{false}}"
    enable-3D="{{false}}"
    markers="{{markers}}"
    bindlabeltap="onLabelTap"
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
  />

  <view class="map-overlay">
    <view class="topbar">
      <view class="avatar-entry" bindtap="onTapLogin">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">{{authStatus === 'loading' ? '...' : '登'}}</view>
        <view class="avatar-copy">
          <text class="avatar-text">{{authText}}</text>
        </view>
      </view>

      <view wx:if="{{authStatus === 'success'}}" class="pair-entry" bindtap="onTapPairEntry">
        <image wx:if="{{pairAvatarUrl}}" class="pair-img" src="{{pairAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="pair-placeholder">♡</view>
        <text class="pair-text">{{pairHintText}}</text>
      </view>

      <view wx:if="{{authStatus === 'success'}}" class="logout-top" catchtap="onLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>

  </view>

  <view wx:if="{{loginPanelVisible}}" class="login-mask" bindtap="onCancelLogin"></view>
  <view wx:if="{{loginPanelVisible}}" class="login-panel">
    <text class="login-title">微信登录</text>
    <text class="login-subtitle">头像和昵称仅用于展示你的地图足迹。</text>

    <view class="avatar-row">
      <image wx:if="{{pendingAvatarUrl}}" class="picker-avatar-img" src="{{pendingAvatarUrl}}" mode="aspectFill" />
      <view wx:else class="picker-avatar-placeholder">头像</view>
      <button class="avatar-picker-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        {{pendingAvatarUrl ? '重新选择' : '选择头像'}}
      </button>
    </view>

    <view class="nick-row">
      <view class="nick-placeholder">昵称</view>
      <button class="nickname-picker-btn" bindtap="onTapNickNamePicker">
        {{pendingNickName ? pendingNickName : '选择昵称'}}
      </button>
      <input
        class="nickname-hidden-input"
        type="nickname"
        focus="{{nickInputFocus}}"
        value="{{pendingNickName}}"
        placeholder="请选择昵称"
        bindblur="onNicknameInput"
      />
    </view>

    <view class="login-actions">
      <button class="cancel-btn" bindtap="onCancelLogin">取消</button>
      <button class="confirm-btn" bindtap="onConfirmLogin">确认登录</button>
    </view>
  </view>

  <view wx:if="{{acceptPanelVisible}}" class="login-mask" bindtap="onCancelAcceptInvite"></view>
  <view wx:if="{{acceptPanelVisible}}" class="login-panel accept-panel">
    <text class="login-title">输入邀请码</text>
    <text class="login-subtitle">把对方给你的邀请码填在下面</text>

    <input
      class="accept-code-input"
      value="{{pendingInviteCode}}"
      maxlength="16"
      placeholder="例如 A1B2C3D4"
      bindinput="onPairCodeInput"
    />

    <view class="login-actions">
      <button class="cancel-btn" bindtap="onCancelAcceptInvite">取消</button>
      <button class="confirm-btn" bindtap="onConfirmAcceptInvite">确认加入</button>
    </view>
  </view>
</view>
