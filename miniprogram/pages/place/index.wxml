<view class="container">
  <view class="header card">
    <text class="title">{{placeTitle}}</text>
  </view>

  <view class="folder-card card">
    <view class="folder-top">
      <text class="folder-title">文件夹</text>
      <text class="folder-add" bindtap="onToggleFolderEditor">+ 新建</text>
    </view>
    <text class="folder-tip">长按文件夹可删除</text>

    <view wx:if="{{folderEditorVisible}}" class="folder-editor">
      <input
        class="folder-input"
        value="{{pendingFolderName}}"
        maxlength="24"
        placeholder="输入文件夹名称"
        bindinput="onFolderNameInput"
      />
      <view class="folder-editor-actions">
        <text class="folder-action cancel" bindtap="onCancelCreateFolder">取消</text>
        <text class="folder-action submit" bindtap="onCreateFolder">创建</text>
      </view>
    </view>

    <scroll-view scroll-x class="folder-scroll">
      <view class="folder-list">
        <view
          class="folder-pill {{selectedFolderId === 'all' ? 'active' : ''}}"
          data-folder-id="all"
          bindtap="onSelectFolder"
        >
          全部 ({{allPhotos.length}})
        </view>
        <view
          wx:for="{{folders}}"
          wx:key="id"
          class="folder-pill {{selectedFolderId === item.folderKey ? 'active' : ''}}"
          data-folder-id="{{item.folderKey}}"
          data-folder-name="{{item.name}}"
          bindtap="onSelectFolder"
          bindlongpress="onFolderLongPress"
        >
          {{item.name}} ({{item.count}})
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{photos.length === 0}}" class="empty card">
    <text class="empty-title">这里还没有照片</text>
    <text class="empty-tip">点击右上角 + 添加，或长按照片移动到文件夹。</text>
  </view>

  <view wx:if="{{photos.length > 0}}" class="grid">
    <view wx:for="{{photos}}" wx:key="id" class="photo-wrap">
      <image
        class="photo"
        src="{{item.filePath}}"
        mode="aspectFill"
        data-path="{{item.filePath}}"
        bindtap="onPreview"
        data-id="{{item.id}}"
        bindlongpress="onPhotoLongPress"
      />
      <text wx:if="{{item.folderName}}" class="folder-tag">{{item.folderName}}</text>
      <text class="time">{{item.timeText}}</text>
    </view>
  </view>

  <view class="fab" bindtap="onAddPhoto">
    <text class="fab-text">+</text>
  </view>
</view>
