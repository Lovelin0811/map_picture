.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: transparent;
}

.card {
  background: var(--surface);
  border-radius: 22rpx;
  padding: 22rpx;
  border: 1rpx solid var(--border-soft);
  box-shadow: 0 10rpx 24rpx rgba(20, 33, 29, 0.08);
  margin-bottom: 18rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
}

.selection-count {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf7f3;
  color: #1f655a;
  font-size: 22rpx;
  font-weight: 600;
}

.empty {
  text-align: center;
}

.folder-card {
  padding-bottom: 16rpx;
}

.folder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.folder-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.folder-add {
  font-size: 24rpx;
  color: var(--brand-main);
  font-weight: 600;
}

.folder-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.folder-editor {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: var(--surface-muted);
}

.folder-input {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-soft);
  font-size: 26rpx;
}

.folder-editor-actions {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
  gap: 22rpx;
}

.folder-action {
  font-size: 24rpx;
}

.folder-action.cancel {
  color: var(--text-secondary);
}

.folder-action.submit {
  color: var(--brand-main);
  font-weight: 600;
}

.folder-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.folder-list {
  display: inline-flex;
  gap: 10rpx;
  padding-bottom: 2rpx;
}

.folder-pill {
  display: inline-block;
  padding: 11rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4f1;
  color: #38524c;
  font-size: 22rpx;
  border: 1rpx solid #dae7e1;
}

.folder-pill.active {
  background: #0f6f64;
  color: #ffffff;
  border-color: #0f6f64;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: var(--text-primary);
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding-bottom: 136rpx;
}

.photo-wrap {
  position: relative;
  padding: 8rpx;
  border-radius: 18rpx;
  background: #f8fcfa;
  border: 1rpx solid #dce9e4;
}

.photo-wrap.is-selected {
  background: #e9f8f3;
  border-color: #63b59f;
}

.photo {
  width: 100%;
  height: 260rpx;
  border-radius: 12rpx;
  background: #dde9e4;
}

.photo-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 8rpx;
}

.time {
  font-size: 21rpx;
  color: var(--text-secondary);
}

.folder-tag {
  font-size: 20rpx;
  color: #1f6a5e;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eaf6f2;
  max-width: 52%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.check-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: rgba(15, 23, 42, 0.32);
}

.check-dot.checked {
  background: #10a278;
}

.batch-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid #dbe8e2;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 32rpx rgba(15, 26, 24, 0.18);
  padding: 14rpx;
  display: flex;
  gap: 10rpx;
  z-index: 110;
}

.batch-chip {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.batch-chip-text {
  font-size: 24rpx;
  font-weight: 600;
}

.batch-chip.ghost {
  background: #f0f6f3;
  border: 1rpx solid #d8e5df;
}

.batch-chip.ghost .batch-chip-text {
  color: #4b655e;
}

.batch-chip.primary {
  background: #0f766e;
}

.batch-chip.primary .batch-chip-text {
  color: #ffffff;
}

.batch-chip.danger {
  background: #d03a4a;
}

.batch-chip.danger .batch-chip-text {
  color: #ffffff;
}

.fab {
  position: fixed;
  top: 20rpx;
  right: 24rpx;
  width: 78rpx;
  height: 78rpx;
  border-radius: 39rpx;
  background: var(--brand-main);
  box-shadow: 0 10rpx 20rpx rgba(18, 130, 114, 0.38);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab-text {
  color: #ffffff;
  font-size: 54rpx;
  line-height: 54rpx;
  transform: translateY(-2rpx);
}
