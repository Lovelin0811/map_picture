.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f6f8fb;
}

.card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 18rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.selection-tools {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.selection-btn {
  font-size: 24rpx;
  color: #0f766e;
}

.selection-count {
  font-size: 22rpx;
  color: #64748b;
}

.coord {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  text-align: center;
}

.folder-card {
  padding-bottom: 16rpx;
}

.folder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.folder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.folder-add {
  font-size: 24rpx;
  color: #0f766e;
}

.folder-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.folder-editor {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.folder-input {
  height: 70rpx;
  padding: 0 18rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}

.folder-editor-actions {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 22rpx;
}

.folder-action {
  font-size: 24rpx;
}

.folder-action.cancel {
  color: #64748b;
}

.folder-action.submit {
  color: #0f766e;
}

.folder-scroll {
  margin-top: 12rpx;
  white-space: nowrap;
}

.folder-list {
  display: inline-flex;
  gap: 10rpx;
  padding-bottom: 2rpx;
}

.folder-pill {
  display: inline-block;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 22rpx;
}

.folder-pill.active {
  background: #0f766e;
  color: #ffffff;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #334155;
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.photo-wrap {
  position: relative;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: #e2e8f0;
}

.time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
}

.folder-tag {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #0f766e;
  text-align: center;
}

.check-dot {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background: rgba(15, 23, 42, 0.3);
}

.check-dot.checked {
  background: #10b981;
}

.batch-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.14);
  padding: 14rpx 18rpx;
  display: flex;
  justify-content: space-between;
  z-index: 110;
}

.batch-btn {
  font-size: 25rpx;
  color: #0f766e;
}

.batch-btn.danger {
  color: #dc2626;
}

.fab {
  position: fixed;
  top: 22rpx;
  right: 24rpx;
  width: 74rpx;
  height: 74rpx;
  border-radius: 37rpx;
  background: #0f766e;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.35);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab-text {
  color: #ffffff;
  font-size: 52rpx;
  line-height: 52rpx;
  transform: translateY(-2rpx);
}
