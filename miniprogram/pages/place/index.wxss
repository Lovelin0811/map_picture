.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f6f8fb;
}

.card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 18rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.coord {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #334155;
}

.empty-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.photo-wrap {
  overflow: hidden;
}

.photo {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #e2e8f0;
}

.time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
}

.fab {
  position: fixed;
  top: 22rpx;
  right: 24rpx;
  width: 74rpx;
  height: 74rpx;
  border-radius: 37rpx;
  background: #0f766e;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.35);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab-text {
  color: #ffffff;
  font-size: 52rpx;
  line-height: 52rpx;
  transform: translateY(-2rpx);
}
