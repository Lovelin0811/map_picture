.container {
  padding: 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: transparent;
}

.card {
  background: var(--bg-elevated);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.selection-count {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: var(--brand-50);
  color: var(--brand-700);
  font-size: 22rpx;
  font-weight: 500;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.folder-card {
  padding-bottom: 20rpx;
}

.folder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.folder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.folder-add {
  font-size: 24rpx;
  color: var(--brand-main);
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  transition: background 0.2s ease;
}

.folder-add:active {
  background: var(--brand-50);
}

.folder-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.folder-editor {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--bg-secondary);
}

.folder-input {
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-medium);
  font-size: 28rpx;
  transition: border-color 0.2s ease;
}

.folder-input:focus {
  border-color: var(--brand-400);
}

.folder-editor-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.folder-action {
  font-size: 26rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.folder-action.cancel {
  color: var(--text-secondary);
}

.folder-action.cancel:active {
  background: var(--gray-100);
}

.folder-action.submit {
  color: var(--brand-main);
  font-weight: 500;
}

.folder-action.submit:active {
  background: var(--brand-50);
}

.folder-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.folder-list {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.folder-pill {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
  background: var(--gray-100);
  color: var(--gray-700);
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid transparent;
  transition: all 0.2s ease;
}

.folder-pill:active {
  background: var(--gray-200);
}

.folder-pill.active {
  background: var(--brand-main);
  color: #ffffff;
  box-shadow: var(--shadow-brand);
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding-bottom: 160rpx;
}

.photo-wrap {
  position: relative;
  border-radius: 16rpx;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-light);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
  transition: all 0.2s ease;
}

.photo-wrap:active {
  transform: scale(0.98);
}

.photo-wrap.is-selected {
  border-color: var(--brand-400);
  box-shadow: 0 0 0 2rpx var(--brand-200), var(--shadow-md);
}

.photo {
  width: 100%;
  height: 280rpx;
  background: var(--gray-200);
  display: block;
}

.photo-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx;
}

.time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

.folder-tag {
  font-size: 20rpx;
  color: var(--brand-700);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  background: var(--brand-50);
  max-width: 55%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.check-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  background: rgba(15, 23, 42, 0.25);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.check-dot.checked {
  background: var(--success-500);
  border-color: var(--success-500);
}

.batch-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid var(--border-light);
  border-radius: 20rpx;
  box-shadow: var(--shadow-xl);
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
  z-index: 110;
  backdrop-filter: blur(10px);
}

.batch-chip {
  flex: 1;
  height: 76rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.batch-chip:active {
  transform: scale(0.97);
}

.batch-chip-text {
  font-size: 26rpx;
  font-weight: 500;
}

.batch-chip.ghost {
  background: var(--gray-100);
  border: 1rpx solid var(--border-light);
}

.batch-chip.ghost .batch-chip-text {
  color: var(--gray-700);
}

.batch-chip.ghost:active {
  background: var(--gray-200);
}

.batch-chip.primary {
  background: var(--brand-main);
  box-shadow: var(--shadow-brand);
}

.batch-chip.primary .batch-chip-text {
  color: #ffffff;
}

.batch-chip.primary:active {
  background: var(--brand-700);
}

.batch-chip.danger {
  background: var(--error-500);
  box-shadow: 0 4rpx 14rpx 0 rgba(239, 68, 68, 0.35);
}

.batch-chip.danger .batch-chip-text {
  color: #ffffff;
}

.batch-chip.danger:active {
  background: #dc2626;
}

.fab {
  position: fixed;
  top: 32rpx;
  right: 32rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--brand-500), var(--brand-700));
  box-shadow: var(--shadow-brand);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  transition: all 0.2s ease;
}

.fab:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.fab-text {
  color: #ffffff;
  font-size: 48rpx;
  line-height: 48rpx;
  font-weight: 300;
}
